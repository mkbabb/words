  "etymology": {
    "text": "From Proto-Indo-European *bʰeg- (a reconstructed root), through a Proto-Germanic form reconstructed as *bankiz/*banki meaning “bench.” This gave rise to medieval Italian banca (bench, moneylender’s table) and Old French banque, from which English borrowed the financial sense “bank” (bench used by moneylenders) by the 15th century; the modern institution sense developed from that use.",
    "origin_language": "Proto-Indo-European",
    "root_words": [
      "*bʰeg-",
      "*bankiz",
      "*banki",
      "bank",
      "banca",
      "banque",
      "banco"
    ],
    "first_known_use": "15th century",
