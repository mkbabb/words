# ─── Floridify Environment Configuration ─────────────────────────────
# Copy to .env and fill in values. Do NOT commit .env to version control.
#
# Single source of truth for database config: auth/config.toml
# This file only controls ports, build targets, and service-level settings.

# ─── Application ─────────────────────────────────────────────────────

ENVIRONMENT=development
LOG_LEVEL=INFO
BUILD_TARGET=development

# ─── Ports (dev.sh will auto-find free ports if these are occupied) ──

BACKEND_PORT=8003
FRONTEND_PORT=3004
MONGO_TUNNEL_PORT=37117

# ─── Frontend ────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:8003
VITE_APP_TITLE=Floridify

# ─── CORS ────────────────────────────────────────────────────────────

BACKEND_CORS_ORIGINS=["http://localhost:3004","http://localhost:5173","http://frontend:3004"]

# ─── Deployment Server ───────────────────────────────────────────────

DEPLOY_HOST=mbabb.fridayinstitute.net
DEPLOY_PORT=1022
DEPLOY_USER=mbabb
DOMAIN=mbabb.friday.institute

# ─── PWA Push Notifications (optional) ───────────────────────────────

NOTIFICATION_PORT=3001
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@floridify.com

# ─── Clerk Authentication (optional) ─────────────────────────────────

VITE_CLERK_PUBLISHABLE_KEY=
CLERK_DOMAIN=
CLERK_SUPER_ADMINS=
